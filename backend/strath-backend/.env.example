# ============================================
# StrathSpace Backend — Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values

# ---- EXISTING (you already have these) ----
DATABASE_URL=postgresql://...
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
APPLE_CLIENT_ID=...
APPLE_CLIENT_SECRET=...
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_BUCKET=...
AWS_REGION=...

# ---- NEW: AGENTIC AI ----

# Gemini API Key (REQUIRED for all AI features)
# Get it from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Daily AI Wingman search/refine budget per user (defaults to 10 if unset)
AGENT_DAILY_SEARCH_LIMIT=10

# ---- NEW: VIBE CHECK (Stage 7) ----

# Daily.co API Key — required for voice call room creation
# Get it from: https://dashboard.daily.co/developers
DAILY_API_KEY=

# Daily.co Domain — full domain shown in your dashboard (e.g. "strathspace.daily.co")
# Find it at: https://dashboard.daily.co/developers → "Your domain"
DAILY_DOMAIN=strathspace.daily.co

# ---- CANDIDATE PAIRS ----

# Cron secret for Vercel cron / external triggers
CRON_SECRET=

# Pair expiry in minutes (default 1440 = 24h). Use 5 for testing.
CANDIDATE_PAIR_EXPIRY_MINUTES=1440

# ---- FACE VERIFICATION ----

# Async is the recommended production mode. Set to "inline" only for local debugging.
FACE_VERIFICATION_PROCESSING_MODE=async

# Number of processing sessions to handle per cron run (default 10, max 100).
FACE_VERIFICATION_CRON_BATCH_SIZE=20

# Number of queued jobs a worker can claim in one run.
FACE_VERIFICATION_WORKER_BATCH_SIZE=20

# Number of jobs a worker processes in parallel.
FACE_VERIFICATION_WORKER_CONCURRENCY=4

# Number of profile-photo comparisons to run in parallel inside one verification session.
FACE_VERIFICATION_COMPARISON_CONCURRENCY=2

# Max profile photos to compare per verification session.
FACE_VERIFICATION_MAX_PROFILE_COMPARISONS=3

# Lease time for claimed queue jobs before another worker can reclaim them.
FACE_VERIFICATION_JOB_LEASE_SECONDS=120

# Max automatic retries for a queued verification job.
FACE_VERIFICATION_JOB_MAX_ATTEMPTS=5

# Base retry delay for queued verification jobs.
FACE_VERIFICATION_JOB_RETRY_DELAY_SECONDS=15

# Analysis version for precomputed profile-photo verification metadata.
FACE_VERIFICATION_PHOTO_AUDIT_VERSION=profile_photo_audit_v1

# ---- MARKETING LANDING (optional overrides) ----
# Defaults are set in src/components/landing/minimal-landing.tsx (App Store + Play).
# NEXT_PUBLIC_IOS_APP_URL=
# NEXT_PUBLIC_ANDROID_APP_URL=
# NEXT_PUBLIC_INSTAGRAM_URL=
# NEXT_PUBLIC_TIKTOK_URL=
