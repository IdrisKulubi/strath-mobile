# ============================================
# StrathSpace Backend — Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values

# ---- EXISTING (you already have these) ----
DATABASE_URL=postgresql://...
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
APPLE_CLIENT_ID=...
APPLE_CLIENT_SECRET=...
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_BUCKET=...
AWS_REGION=...

# ---- ADMIN CAMPAIGNS ----

# Resend API key used by the admin Campaigns page for email delivery.
RESEND_API_KEY=

# Verified Resend sender address or identity. The app forces the inbox display name to "StrathSpace Team".
# Examples: hello@strathspace.com or StrathSpace Team <hello@strathspace.com>
RESEND_FROM_EMAIL=

# Used in campaign templates for {{supportPhone}}.
SUPPORT_WHATSAPP_NUMBER=

# ---- NEW: AGENTIC AI ----

# Gemini API Key (REQUIRED for all AI features)
# Get it from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Daily AI Wingman search/refine budget per user (defaults to 10 if unset)
AGENT_DAILY_SEARCH_LIMIT=10

# ---- CANDIDATE PAIRS ----

# Cron secret for Vercel cron / external triggers
CRON_SECRET=

# Cron endpoints (POST with Authorization: Bearer $CRON_SECRET or x-cron-secret header):
# - /api/admin/expire-pairs
# - /api/admin/meetup-confirm-reminders  (slot confirm deadline ~6h reminder)

# Pair expiry in minutes (default 1440 = 24h). Use 5 for testing.
CANDIDATE_PAIR_EXPIRY_MINUTES=1440

# Minimum compatibility score (0–100) before showing or queueing a candidate pair (default 72).
# Calibrated for the Dice+coverage scoring model: genuinely good matches land in the 80s.
MIN_CANDIDATE_MATCH_SCORE=72

# Max curated introductions per scoring batch: one goes live immediately, the rest queue for later UTC days (default 5).
MAX_CANDIDATE_QUEUE_SIZE=5

# Extra emails excluded from daily candidate matching and swipe mutual matches (comma-separated,
# case-insensitive). Built-in staff emails and any user with user.role=admin or profiles.role=admin
# are always excluded.
# MATCH_EXCLUDED_FROM_POOL_EMAILS=other.staff@example.com

# Hard floor for effective minimum score after relax steps (default 62).
MIN_CANDIDATE_MATCH_SCORE_FLOOR=62

# Fairness: relax minimum score after waiting (only if user already has candidate_pair history).
MATCH_WAIT_DAYS_BEFORE_RELAX=3
MATCH_SCORE_RELAX_PER_STEP=3
MATCH_MAX_SCORE_RELAX_STEPS=4
MATCH_SPARSE_POOL_THRESHOLD=8
MATCH_SPARSE_EXTRA_RELAX_STEPS=1
# Cap on total relax steps (wait + sparse + imbalance).
MATCH_MAX_TOTAL_RELAX_STEPS=6

# Optional: extra relax when opposite-side pool count is below threshold (default off).
# MATCH_IMBALANCE_RELAX_ENABLED=true
# MATCH_IMBALANCE_OPPOSITE_MIN=10

# ---- CAMPUS MEETUP SLOTS (assigned dates) ----
# Auto-schedule uses the default venue set in Admin → Locations (is_default).
# Window times in Africa/Nairobi (24h). Defaults: Wed 17:30, Sat 15:00.
# MEETUP_WED_HOUR=17
# MEETUP_WED_MINUTE=30
# MEETUP_SAT_HOUR=15
# MEETUP_SAT_MINUTE=0
# Hours before the slot when confirmation closes (default 6).
# MEETUP_CONFIRM_LEAD_HOURS=6

# ---- MATCH HOLD (mutual / arranged date) ----
# After both users say "open to meet", the matching pipeline pauses for them until the date
# resolves (cancelled, or completed + feedback). If a date is marked completed and feedback
# is never submitted, this many days later the user is auto-released back into matching.
# Default: 7. Recommended range: 6–10.
MATCH_HOLD_FEEDBACK_GRACE_DAYS=7

# ---- PHOTO-AWARE MATCHING ----

# Optional Railway Python worker for image embeddings (see services/photo-intelligence-worker)
# PHOTO_INTELLIGENCE_SERVICE_URL=https://your-service.up.railway.app
# PHOTO_INTELLIGENCE_SERVICE_SECRET=
# PHOTO_INTELLIGENCE_TIMEOUT_MS=60000
# PHOTO_INTELLIGENCE_MAX_ATTEMPTS=3
# PHOTO_INTELLIGENCE_RETRY_DELAY_MS=2000
# PHOTO_INTELLIGENCE_REQUEST_DELAY_MS=300

# ---- FACE VERIFICATION ----

# Async is the recommended production mode. Set to "inline" only for local debugging.
FACE_VERIFICATION_PROCESSING_MODE=async

# Number of processing sessions to handle per cron run (default 10, max 100).
FACE_VERIFICATION_CRON_BATCH_SIZE=20

# Number of queued jobs a worker can claim in one run.
FACE_VERIFICATION_WORKER_BATCH_SIZE=20

# Number of jobs a worker processes in parallel.
FACE_VERIFICATION_WORKER_CONCURRENCY=4

# Number of profile-photo comparisons to run in parallel inside one verification session.
FACE_VERIFICATION_COMPARISON_CONCURRENCY=3

# Max profile photos to compare per verification session (code default is 4 if unset).
FACE_VERIFICATION_MAX_PROFILE_COMPARISONS=4

# Soft time budget for inline processing on submit before deferring to the queue (ms).
FACE_VERIFICATION_INLINE_BUDGET_MS=12000

# In-process cache for normalized Rekognition image bytes (optional tuning).
# FACE_VERIFICATION_BYTES_CACHE_MAX_ENTRIES=64
# FACE_VERIFICATION_BYTES_CACHE_MAX_BYTES=33554432
# FACE_VERIFICATION_BYTES_CACHE_TTL_MS=300000

# Lease time for claimed queue jobs before another worker can reclaim them.
FACE_VERIFICATION_JOB_LEASE_SECONDS=120

# Max automatic retries for a queued verification job.
FACE_VERIFICATION_JOB_MAX_ATTEMPTS=5

# Base retry delay for queued verification jobs.
FACE_VERIFICATION_JOB_RETRY_DELAY_SECONDS=15

# Analysis version for precomputed profile-photo verification metadata.
FACE_VERIFICATION_PHOTO_AUDIT_VERSION=profile_photo_audit_v1

# ---- MARKETING LANDING (optional overrides) ----
# Defaults are set in src/components/landing/minimal-landing.tsx (App Store + Play).
# NEXT_PUBLIC_IOS_APP_URL=
# NEXT_PUBLIC_ANDROID_APP_URL=
# NEXT_PUBLIC_INSTAGRAM_URL=
# NEXT_PUBLIC_TIKTOK_URL=
